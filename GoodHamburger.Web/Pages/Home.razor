@page "/"
@inject IProductApiService ProductApi

<PageTitle>Cardápio | Good Hamburger</PageTitle>

<div class="page-content">
    <div class="page-header">
        <h1>Nosso Cardápio</h1>
        <p>Conheça nossas deliciosas opções</p>
    </div>

    @if (_loading)
    {
        <div class="spinner"></div>
    }
    else if (_products == null || !_products.Any())
    {
        <div class="empty-state">
            <p>Nenhum produto encontrado no cardápio.</p>
        </div>
    }
    else
    {
        <div class="section-gap">
            <h3 class="text-accent" style="margin-bottom: 1rem;">Sanduíches</h3>
            <div class="card-grid">
                @foreach (var p in _products.Where(p => p.Category == "Sandwich"))
                {
                    <div class="product-card">
                        <span class="product-badge badge-sandwich">Sanduíche</span>
                        <div class="product-name">@p.Name</div>
                        <div class="product-price">R$ @p.Price.ToString("F2")</div>
                    </div>
                }
            </div>
        </div>

        <div class="section-gap">
            <h3 class="text-accent" style="margin-bottom: 1rem;">Acompanhamentos</h3>
            <div class="card-grid">
                @foreach (var p in _products.Where(p => p.Category == "Side"))
                {
                    <div class="product-card">
                        <span class="product-badge badge-side">Acompanhamento</span>
                        <div class="product-name">@p.Name</div>
                        <div class="product-price">R$ @p.Price.ToString("F2")</div>
                    </div>
                }
            </div>
        </div>

        <div class="section-gap">
            <h3 class="text-accent" style="margin-bottom: 1rem;">Bebidas</h3>
            <div class="card-grid">
                @foreach (var p in _products.Where(p => p.Category == "Drink"))
                {
                    <div class="product-card">
                        <span class="product-badge badge-drink">Bebida</span>
                        <div class="product-name">@p.Name</div>
                        <div class="product-price">R$ @p.Price.ToString("F2")</div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private List<ProductModel>? _products;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _products = await ProductApi.GetAllAsync();
        }
        finally
        {
            _loading = false;
        }
    }
}
