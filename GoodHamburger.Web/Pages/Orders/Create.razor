@page "/orders/new"
@inject IProductApiService ProductApi
@inject IOrderApiService OrderApi
@inject NavigationManager Nav

<PageTitle>Novo Pedido | Good Hamburger</PageTitle>

<div class="page-content">
    <div class="page-header">
        <h1>Novo Pedido</h1>
        <p>Monte o pedido selecionando um item de cada categoria</p>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-error">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
            @_error
        </div>
    }

    @if (_loading)
    {
        <div class="spinner"></div>
    }
    else
    {
        <div style="display:grid; grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start;">
            
            <div style="display:flex; flex-direction: column; gap: 2rem;">
                <div>
                    <h3 class="text-accent" style="margin-bottom: 1rem;">1. Escolha o Sanduíche</h3>
                    <div class="card-grid">
                        @foreach (var p in _products.Where(x => x.Category == "Sandwich"))
                        {
                            <div class="product-card @(_sandwichId == p.Id ? "selected" : "")" 
                                 @onclick="() => SelectSandwich(p.Id)" style="cursor:pointer">
                                <span class="product-badge badge-sandwich">Sanduíche</span>
                                <div class="product-name">@p.Name</div>
                                <div class="product-price">R$ @p.Price.ToString("F2")</div>
                            </div>
                        }
                    </div>
                </div>

                <div>
                    <h3 class="text-accent" style="margin-bottom: 1rem;">2. Acompanhamento</h3>
                    <div class="card-grid">
                        @foreach (var p in _products.Where(x => x.Category == "Side"))
                        {
                            <div class="product-card @(_sideId == p.Id ? "selected" : "")" 
                                 @onclick="() => SelectSide(p.Id)" style="cursor:pointer">
                                <span class="product-badge badge-side">Acompanhamento</span>
                                <div class="product-name">@p.Name</div>
                                <div class="product-price">R$ @p.Price.ToString("F2")</div>
                            </div>
                        }
                    </div>
                </div>

                <div>
                    <h3 class="text-accent" style="margin-bottom: 1rem;">3. Bebida</h3>
                    <div class="card-grid">
                        @foreach (var p in _products.Where(x => x.Category == "Drink"))
                        {
                            <div class="product-card @(_drinkId == p.Id ? "selected" : "")" 
                                 @onclick="() => SelectDrink(p.Id)" style="cursor:pointer">
                                <span class="product-badge badge-drink">Bebida</span>
                                <div class="product-name">@p.Name</div>
                                <div class="product-price">R$ @p.Price.ToString("F2")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="totals-panel" style="position: sticky; top: 80px;">
                <h3 style="font-size:1.1rem; margin-bottom:1rem;">Resumo do Pedido</h3>

                @if (_sandwichId == null && _sideId == null && _drinkId == null)
                {
                    <p class="text-muted" style="font-size:.85rem; text-align:center; padding: 2rem 0;">Nenhum item selecionado</p>
                }
                else
                {
                    @if (_sandwichId != null)
                    {
                        var p = _products.First(x => x.Id == _sandwichId);
                        <div class="totals-row">
                            <span>@p.Name</span>
                            <span>R$ @p.Price.ToString("F2")</span>
                        </div>
                    }
                    @if (_sideId != null)
                    {
                        var p = _products.First(x => x.Id == _sideId);
                        <div class="totals-row">
                            <span>@p.Name</span>
                            <span>R$ @p.Price.ToString("F2")</span>
                        </div>
                    }
                    @if (_drinkId != null)
                    {
                        var p = _products.First(x => x.Id == _drinkId);
                        <div class="totals-row">
                            <span>@p.Name</span>
                            <span>R$ @p.Price.ToString("F2")</span>
                        </div>
                    }

                    <div class="totals-row total-final" style="margin-top:1rem;">
                        <span>Subtotal estimado</span>
                        <span>R$ @CalculateEstimatedTotal().ToString("F2")</span>
                    </div>
                    <p class="text-muted" style="font-size:.75rem; margin-top:.2rem;">O desconto final será calculado ao fechar o pedido.</p>
                }

                <button class="btn btn-primary" style="margin-top:1.5rem; justify-content:center;" 
                        disabled="@(!HasAnySelection() || _submitting)" @onclick="SubmitOrder">
                    @(_submitting ? "Processando..." : "Finalizar Pedido")
                </button>
            </div>

        </div>
    }
</div>

@code {
    private bool _loading = true;
    private bool _submitting = false;
    private string? _error;
    private List<ProductModel> _products = new();

    private Guid? _sandwichId;
    private Guid? _sideId;
    private Guid? _drinkId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _products = await ProductApi.GetAllAsync();
        }
        catch (Exception)
        {
            _error = "Erro ao carregar o cardápio.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectSandwich(Guid id) => _sandwichId = _sandwichId == id ? null : id;
    private void SelectSide(Guid id) => _sideId = _sideId == id ? null : id;
    private void SelectDrink(Guid id) => _drinkId = _drinkId == id ? null : id;

    private bool HasAnySelection() => _sandwichId != null || _sideId != null || _drinkId != null;

    private decimal CalculateEstimatedTotal()
    {
        decimal t = 0;
        if (_sandwichId != null) t += _products.First(x => x.Id == _sandwichId).Price;
        if (_sideId != null) t += _products.First(x => x.Id == _sideId).Price;
        if (_drinkId != null) t += _products.First(x => x.Id == _drinkId).Price;
        return t;
    }

    private async Task SubmitOrder()
    {
        if (!HasAnySelection()) return;

        _submitting = true;
        _error = null;

        var request = new CreateOrderRequest();
        if (_sandwichId != null) request.Items.Add(new CreateOrderItemRequest { ProductId = _sandwichId.Value, Quantity = 1 });
        if (_sideId != null) request.Items.Add(new CreateOrderItemRequest { ProductId = _sideId.Value, Quantity = 1 });
        if (_drinkId != null) request.Items.Add(new CreateOrderItemRequest { ProductId = _drinkId.Value, Quantity = 1 });

        try
        {
            var (order, err) = await OrderApi.CreateAsync(request);
            if (err != null)
            {
                _error = err;
            }
            else
            {
                Nav.NavigateTo("/orders");
            }
        }
        catch (Exception)
        {
            _error = "Erro de conexão ao enviar o pedido.";
        }
        finally
        {
            _submitting = false;
        }
    }
}
